# =============================================================================
# hospitality-compliance-rag — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI
# Required for: GPT-4o-mini answer generation (runtime) and RAGAS evaluation
# Get your key at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# The OpenAI chat model used at generation time.
# Default: gpt-4o-mini (cost-efficient, sufficient for RAG)
OPENAI_MODEL=gpt-4o-mini

# Generation temperature. Low = factual/grounded, High = creative.
# Recommended: 0.1 for compliance use-cases
OPENAI_TEMPERATURE=0.1

# Maximum tokens in the generated answer.
OPENAI_MAX_TOKENS=768

# -----------------------------------------------------------------------------
# Pinecone
# Required for: vector upsert (ingestion) and dense retrieval (runtime)
# Get your key at: https://app.pinecone.io/
# -----------------------------------------------------------------------------
PINECONE_API_KEY=pcsk_...

# The name of the Pinecone index.
# Must match what was created during ingestion.
PINECONE_INDEX_NAME=hospitality-compliance

# Pinecone namespace — logical partition within the index.
PINECONE_NAMESPACE=hospitality-kb

# Cloud provider for the Pinecone serverless index.
PINECONE_CLOUD=aws

# Cloud region for the Pinecone serverless index.
PINECONE_REGION=us-east-1

# Embedding dimensions.
# Must match the hosted inference model output.
# multilingual-e5-large = 1024 | llama-text-embed-v2 = 1024
# text-embedding-3-small = 1536
PINECONE_DIMENSION=1024

# Distance metric for vector similarity.
PINECONE_METRIC=cosine

# Name of the Pinecone-hosted inference model used to embed queries at runtime.
# This model MUST match what was used during ingestion (embedder.py).
# Options: multilingual-e5-large, llama-text-embed-v2
PINECONE_EMBED_MODEL=multilingual-e5-large

# -----------------------------------------------------------------------------
# BM25 retrieval
# Path where the serialised BM25 index is written by ingestion
# and read by the runtime. Must be consistent between both.
# -----------------------------------------------------------------------------
BM25_INDEX_PATH=retrieval/bm25_index.pkl

# BM25 Okapi parameters (Robertson & Zaragoza 2009 defaults)
BM25_K1=1.5
BM25_B=0.75

# -----------------------------------------------------------------------------
# Hybrid Retrieval — candidate sizes fed into RRF
# -----------------------------------------------------------------------------
TOP_K_BM25=7
TOP_K_DENSE=7
TOP_K_FINAL=5

# Reciprocal Rank Fusion smoothing constant (Robertson 2009 default = 60)
RRF_K=60

# -----------------------------------------------------------------------------
# Chunking (ingestion only)
# These are approximate whitespace-token counts, not BPE tokens.
# -----------------------------------------------------------------------------
MAX_CHUNK_TOKENS=600
MIN_CHUNK_TOKENS=80
